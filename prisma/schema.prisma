generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id          String   @id @default(cuid())
  name        String
  email       String?
  phone       String?
  company     String?
  projectType String?
  budget      String?
  timeline    String?
  message     String
  source      String   @default("website")
  createdAt   DateTime @default(now())
}
